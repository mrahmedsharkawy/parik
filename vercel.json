{
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    { "source": "/favicon.ico", "destination": "/assets/logo.png" },
    { "source": "/assets/favicon.svg", "destination": "/assets/logo.png" },
    { "source": "/assets/categories/sticker/:file", "destination": "/assets/categories/Sticker/:file" },
    { "source": "/assets/categories/ramadan/:file", "destination": "/assets/categories/Ramadan/:file" },
    { "source": "/assets/categories/forex/:file", "destination": "/assets/categories/Forex/:file" },
    { "source": "/affiliate-program", "destination": "/affiliate" },
    { "source": "/affiliate-program.html", "destination": "/affiliate" },
    { "source": "/categories/:path*", "destination": "/categories.html" },
    { "source": "/policy/:slug", "destination": "/policy" },
    { "source": "/product/:id/:slug", "destination": "/product" },
    { "source": "/product/:id",       "destination": "/product" }
  ],
  "headers": [
    {
      "source": "/sw.js",
      "headers": [{ "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }]
    },
    {
      "source": "/:path*.html",
      "headers": [{ "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }]
    },
    {
      "source": "/assets/:path*",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }]
    },
    {
      "source": "/style/:path*",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=2592000, stale-while-revalidate=604800" }]
    },
    {
      "source": "/java/:path*",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=2592000, stale-while-revalidate=604800" }]
    },
    {
      "source": "/mobile-nav-bar/:path*",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=2592000, stale-while-revalidate=604800" }]
    },
    {
      "source": "/translations/:path*",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=2592000, stale-while-revalidate=604800" }]
    }
  ]
}
